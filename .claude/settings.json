{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'r=\"$(pwd)\";while [ ! -d \"$r/.claude/hooks\" ];do p=\"$(dirname \"$r\")\";[ \"$p\" = \"$r\" ]&&exit 0;r=\"$p\";done;exec \"$r/.claude/hooks/pre-edit-main-guard.sh\"'",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'r=\"$(pwd)\";while [ ! -d \"$r/.claude/hooks\" ];do p=\"$(dirname \"$r\")\";[ \"$p\" = \"$r\" ]&&exit 0;r=\"$p\";done;exec \"$r/.claude/hooks/pre-bash-firewall.sh\"'",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'r=\"$(pwd)\";while [ ! -d \"$r/.claude/hooks\" ];do p=\"$(dirname \"$r\")\";[ \"$p\" = \"$r\" ]&&exit 0;r=\"$p\";done;exec node \"$r/.claude/hooks/track-edit.js\"'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'r=\"$(pwd)\";while [ ! -d \"$r/.claude/hooks\" ];do p=\"$(dirname \"$r\")\";[ \"$p\" = \"$r\" ]&&exit 0;r=\"$p\";done;exec node \"$r/.claude/hooks/track-bash.js\"'"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'r=\"$(pwd)\";while [ ! -d \"$r/.claude/hooks\" ];do p=\"$(dirname \"$r\")\";[ \"$p\" = \"$r\" ]&&exit 0;r=\"$p\";done;exec node \"$r/.claude/hooks/track-prompt.js\"'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'r=\"$(pwd)\";while [ ! -d \"$r/.claude/hooks\" ];do p=\"$(dirname \"$r\")\";[ \"$p\" = \"$r\" ]&&exit 0;r=\"$p\";done;exec node \"$r/.claude/hooks/diary-stop.js\"'"
          }
        ]
      }
    ]
  }
}
